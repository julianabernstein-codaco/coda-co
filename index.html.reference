</div>
</div>
<div class="wd" style="background:var(--svp);"></div>
<footer style="border-radius:50% 50% 0 0/60px 60px 0 0;"><div class="ft-inner"><div><div class="fb-n"><span class="ca">Coda</span><span class="co">Co</span></div><p class="fb-p">A curated marketplace for death and dying. Built with care.</p></div><div class="fc"><h4>Shop</h4><a onclick="go(3)">Urns &amp; vessels</a><a onclick="go(3)">Ash jewelry</a><a onclick="go(3)">Burial shrouds</a><a onclick="go(3)">Planning docs</a></div><div class="fc"><h4>Services</h4><a onclick="go(1)">Death doulas</a><a onclick="go(1)">Estate attorneys</a><a onclick="go(1)">Death cleaning</a><a onclick="go(1)">Celebrants</a></div><div class="fc"><h4>Company</h4><a onclick="go(0)">About CodaCo</a><a onclick="go(4)">List with us</a><a>Help &amp; FAQ</a><a>Privacy policy</a></div></div><div class="ft-bottom"><span>© 2025 CodaCo, Inc. · United States</span><div class="ft-legal"><a>Terms of service</a><a>Privacy policy</a><a>Accessibility</a><a>Cookie preferences</a></div><span>Made with intention.</span></div></footer>
</div>

</div><!-- end #app -->

<script>
function go(n){
  document.querySelectorAll('.pg').forEach(function(p){p.classList.remove('on');});
  document.getElementById('p'+n).classList.add('on');
  window.scrollTo(0,0);
}
function toggleGuide(){
  var gp=document.getElementById('gp');
  gp.classList.toggle('open');
}
function showSub(id){
  document.getElementById('gb').style.display='none';
  ['recently','planning','memorial','learn'].forEach(function(k){
    document.getElementById('gs-'+k).classList.remove('open');
  });
  document.getElementById('gs-'+id).classList.add('open');
}
function resetGuide(){
  document.getElementById('gb').style.display='grid';
  ['recently','planning','memorial','learn'].forEach(function(k){
    document.getElementById('gs-'+k).classList.remove('open');
  });
}
function doSearch(id){
  var q=document.getElementById(id).value.trim();
  if(q) alert('Searching for: '+q+'\n\n(In the live site this would navigate to search results.)');
}
function adjQ(d){
  var el=document.getElementById('qv');
  var v=Math.max(1,parseInt(el.textContent)+d);
  el.textContent=v;
  document.getElementById('aBtn').textContent='Add to cart — $'+(145*v);
}
function showTab(id){
  document.querySelectorAll('.tab-pane').forEach(function(p){p.classList.remove('on');});
  document.querySelectorAll('.pdp-tab').forEach(function(t){t.classList.remove('on');});
  document.getElementById('td-'+id).classList.add('on');
  var idx={desc:0,det:1,rev:2,sel:3};
  document.querySelectorAll('.pdp-tab')[idx[id]].classList.add('on');
}
function selPlan(el){
  document.querySelectorAll('.plan-c').forEach(function(c){c.classList.remove('on');});
  el.classList.add('on');
  var nm=el.querySelector('.plan-name').textContent;
  var pr=el.querySelector('.plan-price').childNodes[0].textContent.trim();
  var fee=nm==='Pro'?'3% transaction fee on sales':'5% transaction fee on sales';
  var ps=document.getElementById('plan-summary');
  if(ps) ps.innerHTML=nm+' — '+pr+'/month<br><span style="font-size:12px;color:var(--cl);">'+fee+'</span>';
}
function toggleFaq(n){
  var b=document.getElementById('fb'+n);
  var i=document.getElementById('fi'+n);
  var open=b.style.display==='block';
  b.style.display=open?'none':'block';
  i.textContent=open?'+':'−';
}
function selRc(el,grp){
  el.closest('.fg').querySelectorAll('.rc-card').forEach(function(r){r.classList.remove('on');});
  el.classList.add('on');
}
function selRcGroup(el,grp){
  el.closest('.form-section').querySelectorAll('[onclick*="\''+grp+'\'"]').forEach(function(r){r.classList.remove('on');});
  el.classList.add('on');
}
function addRow(){
  var t=document.getElementById('ptable');
  var r=document.createElement('div');
  r.className='price-row';
  r.innerHTML='<input class="fi" placeholder="Variant name" style="font-size:13px;"/><input class="fi" placeholder="Price $" style="width:80px;font-size:13px;"/><input class="fi" placeholder="Stock" style="width:70px;font-size:13px;"/><button class="price-del" onclick="delRow(this)">×</button>';
  t.appendChild(r);
}
function delRow(btn){
  var row=btn.closest('.price-row');
  if(document.querySelectorAll('.price-row').length>1) row.remove();
}
document.querySelectorAll('.avail-day').forEach(function(d){
  d.addEventListener('click',function(){this.classList.toggle('on');});
});
document.querySelectorAll('.cp, .cp.sg-pill').forEach(function(c){
  c.addEventListener('click',function(){this.classList.toggle('on');});
});
document.querySelectorAll('.fp').forEach(function(b){
  b.addEventListener('click',function(){
    var par=this.parentNode;
    par.querySelectorAll('.fp').forEach(function(s){s.classList.remove('on');});
    this.classList.add('on');
  });
});
document.querySelectorAll('.sz').forEach(function(b){
  b.addEventListener('click',function(){
    this.closest('.sz-row').querySelectorAll('.sz').forEach(function(s){s.classList.remove('on');});
    this.classList.add('on');
  });
});
document.querySelectorAll('.sw').forEach(function(b){
  b.addEventListener('click',function(){
    this.closest('.swatches').querySelectorAll('.sw').forEach(function(s){s.classList.remove('on');});
    this.classList.add('on');
  });
});
</script>
</body>
</html>
