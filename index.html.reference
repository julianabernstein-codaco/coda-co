<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>CodaCo — A curated marketplace for death and dying</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet"/>
<style>
:root{
  --tr:#C1634F;--tl:#D4876F;--tp:#F5EAE6;--td:#8B3E2D;--tvp:#FCF4F1;
  --sg:#7A9E82;--sl:#A8C4AC;--sp:#EAF0EB;--sd:#4D7255;--svp:#F1F7F2;
  --wh:#FFFFFF;--pl:#FAF9F7;--pl2:#F3F1EE;
  --ch:#2C2825;--cm:#5A534C;--cl:#9A9189;
  --sf:'Cormorant Garamond',Georgia,serif;
  --ss:'DM Sans',system-ui,sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:var(--ss);background:var(--wh);color:var(--ch);font-size:15px;line-height:1.6;overflow-x:hidden;}
.pg{display:none;}.pg.on{display:block;}

/* ── NAV ── */
nav{background:var(--wh);border-bottom:1px solid rgba(44,40,37,.07);padding:0 2.5rem;display:flex;align-items:center;justify-content:space-between;height:68px;position:sticky;top:0;z-index:100;}
.logo{display:flex;align-items:center;gap:13px;cursor:pointer;text-decoration:none;}
.ln{font-family:var(--sf);font-size:30px;font-weight:500;letter-spacing:.02em;line-height:1;}
.ln .ca{color:var(--tr);}.ln .co{color:var(--sg);}
.lt{font-size:10px;letter-spacing:.11em;text-transform:uppercase;color:var(--cl);margin-top:3px;white-space:nowrap;}
.nl{display:flex;gap:1.5rem;align-items:center;list-style:none;}
.nl a{text-decoration:none;font-size:13px;color:var(--cm);cursor:pointer;transition:color .15s;}
.nl a:hover{color:var(--tr);}
.nl .cta{background:var(--tr)!important;color:var(--wh)!important;padding:7px 17px;border-radius:20px;}
.nl .cta:hover{background:var(--td)!important;}
.nl a.act{color:var(--tr);font-weight:500;}

/* ── BREADCRUMB ── */
.bc{padding:.65rem 2.5rem;font-size:12px;color:var(--cl);background:var(--tvp);border-bottom:1px solid rgba(193,99,79,.1);}
.bc a{color:var(--tr);cursor:pointer;text-decoration:none;}
.bc a:hover{text-decoration:underline;}
.bc span{margin:0 6px;}

/* ── WAVE SYSTEM ── */
.wd{padding-bottom:60px;margin-bottom:-60px;}
.wu{border-radius:50% 50% 0 0/60px 60px 0 0;}

/* ── TYPOGRAPHY ── */
.ey{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--tr);margin-bottom:.35rem;}
.eys{color:var(--sg);}
.sh{font-family:var(--sf);font-size:32px;font-weight:300;color:var(--ch);margin-bottom:.25rem;}
.st{font-size:13px;color:var(--cl);}
.shd{text-align:center;margin-bottom:1.75rem;}
.va{display:inline-block;margin-top:1.25rem;font-size:13px;color:var(--tr);border-bottom:1px dotted var(--tl);cursor:pointer;}
.va:hover{color:var(--td);}
.ctr{text-align:center;}

/* ── BUTTONS ── */
.btn-p{background:var(--tr);color:var(--wh);border:none;padding:13px 30px;border-radius:26px;font-size:14px;cursor:pointer;font-family:var(--ss);transition:background .18s;}
.btn-p:hover{background:var(--td);}
.btn-s{background:transparent;color:var(--ch);border:1.5px solid rgba(44,40,37,.25);padding:12px 26px;border-radius:26px;font-size:13px;cursor:pointer;font-family:var(--ss);transition:all .18s;}
.btn-s:hover{border-color:var(--tr);color:var(--tr);}

/* ── BADGES ── */
.badge{display:inline-block;font-size:10px;padding:2px 7px;border-radius:9px;margin-left:4px;}
.bm{background:var(--tp);color:var(--td);}
.bl{background:var(--sp);color:var(--sd);}

/* ── CATEGORY GRID ── */
.cat-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:12px;}
.cc{background:var(--wh);border:1px solid rgba(44,40,37,.09);border-radius:12px;padding:1.2rem 1rem;text-align:center;cursor:pointer;transition:all .18s;text-decoration:none;display:block;}
.cc:hover{border-color:var(--tl);transform:translateY(-2px);}
.ciw{width:40px;height:40px;margin:0 auto .7rem;display:flex;align-items:center;justify-content:center;}
.ct2{font-size:12px;font-weight:500;color:var(--ch);line-height:1.3;}

/* ── SERVICE CARDS ── */
.sv-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px;}
.sv-c{background:var(--wh);border:1px solid rgba(44,40,37,.09);border-radius:10px;padding:1.25rem;cursor:pointer;transition:all .18s;}
.sv-c:hover{border-color:var(--sl);}
.sv-av{width:40px;height:40px;border-radius:50%;background:var(--sp);border:1.5px solid var(--sl);display:flex;align-items:center;justify-content:center;font-family:var(--sf);font-size:16px;color:var(--sd);margin-bottom:.75rem;}
.sv-nm{font-size:14px;font-weight:500;color:var(--ch);margin-bottom:2px;}
.sv-tp{font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:var(--cl);margin-bottom:7px;}
.sv-lc{font-size:12px;color:var(--cm);margin-bottom:5px;}
.sv-rt{font-size:12px;color:var(--tr);}

/* ── PRODUCT CARDS ── */
.pr-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(178px,1fr));gap:16px;}
.pr-c{background:var(--wh);border:1px solid rgba(44,40,37,.08);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .18s;}
.pr-c:hover{border-color:rgba(193,99,79,.3);transform:translateY(-2px);}
.pr-i{height:130px;display:flex;align-items:center;justify-content:center;}
.pr-b{padding:.75rem 1rem .95rem;}
.pr-t{font-size:13px;font-weight:500;color:var(--ch);margin-bottom:3px;line-height:1.35;}
.pr-s{font-size:11px;color:var(--cl);margin-bottom:6px;}
.pr-p{font-size:14px;font-weight:500;color:var(--tr);}

/* ── BOOK CARDS ── */
.bk-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(158px,1fr));gap:16px;}
.bk-c{background:var(--wh);border:1px solid rgba(44,40,37,.08);border-radius:10px;overflow:hidden;cursor:pointer;transition:all .18s;}
.bk-c:hover{transform:translateY(-2px);}
.bk-cv{height:168px;display:flex;align-items:flex-end;padding:14px;position:relative;overflow:hidden;}
.bkh{font-family:var(--sf);font-size:17px;font-weight:400;color:rgba(255,255,255,.95);line-height:1.2;position:relative;z-index:1;}
.bka{font-size:11px;color:rgba(255,255,255,.7);margin-top:4px;font-style:italic;position:relative;z-index:1;}
.bk-b{padding:.75rem 1rem;}
.bk-d{font-size:12px;color:var(--cm);line-height:1.5;margin-bottom:7px;}
.bk-l{font-size:12px;color:var(--tr);border-bottom:1px dotted var(--tl);cursor:pointer;}

/* ── HUMOR ── */
.hm-bnr{background:var(--ch);border-radius:12px;padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:1.5rem;}
.hm-bnr h3{font-family:var(--sf);font-size:24px;font-weight:300;color:var(--tvp);margin-bottom:3px;}
.hm-bnr p{font-size:13px;color:rgba(252,244,241,.6);max-width:340px;}
.hm-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(158px,1fr));gap:14px;}
.hm-c{background:var(--wh);border:1px solid rgba(44,40,37,.08);border-radius:10px;padding:.9rem;text-align:center;cursor:pointer;transition:all .18s;}
.hm-c:hover{border-color:var(--cl);}
.hm-p{height:86px;background:var(--ch);border-radius:7px;display:flex;align-items:center;justify-content:center;margin-bottom:.7rem;font-family:var(--sf);font-size:12px;color:rgba(252,244,241,.85);padding:.75rem;line-height:1.45;font-style:italic;}
.hm-tt{font-size:12px;color:var(--ch);font-weight:500;}
.hm-pr{font-size:12px;color:var(--tr);margin-top:2px;}

/* ── LOCATION BAR ── */
.loc-bar{display:flex;align-items:center;gap:10px;background:var(--wh);border:1px solid rgba(44,40,37,.1);border-radius:8px;padding:10px 16px;margin-bottom:1.5rem;}
.loc-bar span{font-size:13px;color:var(--cm);flex:1;}
.loc-bar input{border:none;background:transparent;font-family:var(--ss);font-size:13px;color:var(--tr);font-weight:500;outline:none;width:200px;}
.loc-btn{background:var(--sg);color:var(--wh);border:none;padding:6px 15px;border-radius:18px;font-size:12px;cursor:pointer;font-family:var(--ss);}

/* ── VENDOR CTA ── */
.vd-steps{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1rem;max-width:680px;margin:0 auto 2rem;}
.vs{background:var(--wh);border-radius:10px;padding:1.25rem 1rem;text-align:center;border:1px solid rgba(44,40,37,.07);}
.vsn{width:30px;height:30px;border-radius:50%;background:var(--tr);color:var(--wh);font-size:13px;font-weight:500;display:flex;align-items:center;justify-content:center;margin:0 auto .7rem;}
.vst{font-size:13px;font-weight:500;color:var(--ch);margin-bottom:3px;}
.vsd{font-size:12px;color:var(--cl);line-height:1.45;}

/* ── FOOTER ── */
footer{background:var(--ch);padding:3rem 2.5rem 2rem;}
.ft-inner{max-width:900px;margin:0 auto;display:grid;grid-template-columns:1.8fr 1fr 1fr 1fr;gap:2rem;padding-bottom:2.5rem;border-bottom:1px solid rgba(252,244,241,.1);}
.fb-n{font-family:var(--sf);font-size:22px;font-weight:500;margin-bottom:.6rem;}
.fb-n .ca{color:var(--tl);}.fb-n .co{color:var(--sl);}
.fb-p{font-size:12px;color:rgba(252,244,241,.45);line-height:1.7;max-width:220px;}
.ft-inner .fc h4{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(252,244,241,.35);margin-bottom:12px;font-weight:500;}
.ft-inner .fc a{display:block;font-size:13px;color:rgba(252,244,241,.6);text-decoration:none;margin-bottom:9px;cursor:pointer;transition:color .15s;}
.ft-inner .fc a:hover{color:var(--tl);}
.ft-mid{max-width:900px;margin:0 auto;padding:1.75rem 0 1.5rem;border-bottom:1px solid rgba(252,244,241,.07);display:grid;grid-template-columns:1fr 1fr;gap:2rem;align-items:center;}
.ft-nl p{font-size:13px;color:rgba(252,244,241,.6);margin-bottom:.75rem;}
.ft-nl-row{display:flex;max-width:340px;}
.ft-nl-row input{flex:1;padding:9px 14px;border:1px solid rgba(252,244,241,.2);border-right:none;border-radius:20px 0 0 20px;background:rgba(252,244,241,.07);font-family:var(--ss);font-size:13px;color:rgba(252,244,241,.85);outline:none;}
.ft-nl-row input::placeholder{color:rgba(252,244,241,.35);}
.ft-nl-row button{background:var(--tr);color:var(--wh);border:none;padding:9px 16px;border-radius:0 20px 20px 0;font-size:13px;font-family:var(--ss);cursor:pointer;}
.ft-social p{font-size:13px;color:rgba(252,244,241,.6);margin-bottom:.75rem;}
.ft-social-links{display:flex;gap:10px;}
.sp-pill{background:rgba(252,244,241,.08);border:1px solid rgba(252,244,241,.12);border-radius:18px;padding:6px 14px;font-size:12px;color:rgba(252,244,241,.55);cursor:pointer;font-family:var(--ss);transition:all .15s;}
.sp-pill:hover{background:rgba(252,244,241,.14);color:rgba(252,244,241,.85);}
.ft-bottom{max-width:900px;margin:0 auto;padding-top:1.5rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
.ft-bottom span{font-size:12px;color:rgba(252,244,241,.3);}
.ft-legal{display:flex;gap:1.25rem;}
.ft-legal a{font-size:12px;color:rgba(252,244,241,.35);text-decoration:none;cursor:pointer;}
.ft-legal a:hover{color:rgba(252,244,241,.65);}

/* ── HERO ── */
.hero{background:var(--wh);padding:4.5rem 2.5rem 3rem;text-align:center;}
.hero h1{font-family:var(--sf);font-size:52px;font-weight:300;line-height:1.12;color:var(--ch);margin-bottom:1.2rem;}
.hero h1 em{font-style:italic;color:var(--tr);}
.hero-tag{font-size:15px;color:var(--cm);max-width:560px;margin:0 auto .5rem;line-height:1.78;}
.hero-tag2{font-size:14px;color:var(--cl);font-style:italic;margin-bottom:2rem;}
.hs-row{display:flex;max-width:500px;margin:0 auto 1rem;}
.hs-row input{flex:1;padding:14px 20px;border:1.5px solid rgba(193,99,79,.25);border-right:none;border-radius:28px 0 0 28px;background:var(--wh);font-family:var(--ss);font-size:14px;color:var(--ch);outline:none;}
.hs-row input:focus{border-color:var(--tr);}
.hs-row input::placeholder{color:var(--cl);}
.hs-row button{background:var(--tr);color:var(--wh);border:none;padding:14px 22px;border-radius:0 28px 28px 0;font-family:var(--ss);font-size:13px;cursor:pointer;transition:background .18s;}
.hs-row button:hover{background:var(--td);}
.hero-guide-txt{font-size:13px;color:var(--cl);margin-bottom:.35rem;}
.hero-guide-txt a{color:var(--tr);cursor:pointer;border-bottom:1px dotted var(--tl);}
.hero-guide-txt a:hover{color:var(--td);}

/* ── GUIDED SEARCH PANEL ── */
.gp{background:var(--wh);border:1px solid var(--tp);border-radius:12px;padding:1.5rem;max-width:620px;margin:1.25rem auto 0;display:none;text-align:left;}
.gp.open{display:block;}
.gp h3{font-family:var(--sf);font-size:21px;font-weight:400;color:var(--ch);margin-bottom:1rem;}
.gb{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.gb-btn{background:var(--pl);border:1px solid rgba(44,40,37,.09);border-radius:8px;padding:14px;text-align:left;cursor:pointer;font-family:var(--ss);transition:all .18s;}
.gb-btn:hover{border-color:var(--tl);background:var(--tvp);}
.gb-btn.featured{background:var(--tvp);border:1.5px solid var(--tp);}
.gb-btn.featured:hover{border-color:var(--tr);}
.gb-title{font-size:13px;font-weight:500;color:var(--ch);display:block;}
.gb-desc{font-size:12px;color:var(--cl);display:block;margin-top:2px;}
.gs{display:none;margin-top:.75rem;}
.gs.open{display:block;}
.sub-tags{display:flex;flex-wrap:wrap;gap:7px;margin-top:.6rem;}
.sub-tag{background:var(--sp);color:var(--sd);border:1px solid var(--sl);padding:5px 13px;border-radius:18px;font-size:12px;cursor:pointer;transition:all .15s;}
.sub-tag:hover{background:var(--sl);}
.guide-back{font-size:12px;color:var(--cl);cursor:pointer;background:none;border:none;font-family:var(--ss);padding:0;margin-top:.8rem;display:block;}
.guide-back:hover{color:var(--tr);}
.guide-toggle-lnk{font-size:13px;color:var(--cl);}
.guide-toggle-lnk a{color:var(--tr);cursor:pointer;border-bottom:1px dotted var(--tl);}

/* ── SERVICES SEARCH PAGE ── */
.svc-ph-hd{background:var(--wh);padding:1.5rem 2.5rem 1.25rem;border-bottom:1px solid rgba(44,40,37,.07);}
.sbar-wrap{display:flex;gap:10px;flex-wrap:wrap;align-items:center;max-width:880px;margin:0 auto;}
.sbar{display:flex;flex:1;min-width:200px;border:1.5px solid rgba(193,99,79,.22);border-radius:8px;overflow:hidden;background:var(--wh);}
.sbar-loc{display:flex;flex:1;min-width:180px;border:1.5px solid rgba(44,40,37,.15);border-radius:8px;overflow:hidden;background:var(--wh);}
.sbar .si,.sbar-loc .si{padding:10px 12px;border-right:1px solid rgba(44,40,37,.09);display:flex;align-items:center;}
.sbar input,.sbar-loc input{flex:1;border:none;padding:10px 14px;font-family:var(--ss);font-size:13px;color:var(--ch);outline:none;background:transparent;}
.search-go{background:var(--tr);color:var(--wh);border:none;padding:11px 22px;border-radius:8px;font-size:13px;font-family:var(--ss);cursor:pointer;white-space:nowrap;transition:background .18s;}
.search-go:hover{background:var(--td);}
.fl-layout{display:grid;grid-template-columns:210px 1fr;gap:0;max-width:880px;margin:0 auto;}
.filter-col{padding:1.5rem 1.25rem 2rem 0;border-right:1px solid rgba(44,40,37,.08);}
.f-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;}
.f-hd span{font-size:13px;font-weight:500;color:var(--ch);}
.clr-btn{font-size:12px;color:var(--cl);background:none;border:none;font-family:var(--ss);cursor:pointer;text-decoration:underline;}
.clr-btn:hover{color:var(--tr);}
.f-sec{margin-bottom:1.4rem;}
.f-sec h4{font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--cl);margin-bottom:.65rem;font-weight:500;}
.f-div{height:1px;background:rgba(44,40,37,.07);margin:1.1rem 0;}
.f-pills{display:flex;flex-wrap:wrap;gap:5px;}
.fp{background:var(--pl);border:1px solid rgba(44,40,37,.12);color:var(--cm);padding:5px 11px;border-radius:14px;font-size:12px;cursor:pointer;font-family:var(--ss);transition:all .15s;}
.fp:hover,.fp.on{background:var(--tr);color:var(--wh);border-color:var(--tr);}
.f-chk{display:flex;align-items:center;gap:8px;margin-bottom:8px;cursor:pointer;}
.f-chk input{accent-color:var(--tr);width:13px;height:13px;}
.f-chk span{font-size:12px;color:var(--cm);}
.res-col{padding:1.5rem 0 2rem 1.5rem;}
.res-tb{display:flex;align-items:center;justify-content:space-between;margin-bottom:1.25rem;}
.res-count{font-size:13px;color:var(--cm);}
.sort-row{display:flex;align-items:center;gap:7px;}
.sort-row label{font-size:12px;color:var(--cl);}
.sort-row select{font-size:12px;color:var(--cm);border:1px solid rgba(44,40,37,.15);border-radius:6px;padding:5px 10px;background:var(--wh);font-family:var(--ss);outline:none;}
.map-ph{background:var(--pl2);border:1px solid rgba(44,40,37,.1);border-radius:10px;height:155px;display:flex;align-items:center;justify-content:center;margin-bottom:1.25rem;}
.src-c{background:var(--wh);border:1px solid rgba(44,40,37,.09);border-radius:10px;padding:1.1rem 1.25rem;margin-bottom:12px;cursor:pointer;display:grid;grid-template-columns:48px 1fr auto;gap:12px;align-items:start;transition:all .18s;}
.src-c:hover{border-color:var(--sl);}
.src-av{width:48px;height:48px;border-radius:50%;background:var(--sp);border:1.5px solid var(--sl);display:flex;align-items:center;justify-content:center;font-family:var(--sf);font-size:18px;color:var(--sd);flex-shrink:0;}
.src-nm{font-size:14px;font-weight:500;color:var(--ch);margin-bottom:2px;}
.src-badge{display:inline-block;font-size:10px;letter-spacing:.07em;text-transform:uppercase;background:var(--sp);color:var(--sd);border:1px solid var(--sl);padding:2px 9px;border-radius:10px;margin-bottom:6px;}
.src-bio{font-size:12px;color:var(--cm);line-height:1.5;margin-bottom:6px;}
.src-meta{display:flex;gap:12px;flex-wrap:wrap;}
.src-meta span{font-size:12px;color:var(--cl);}
.src-meta strong{color:var(--cm);}
.src-rt{text-align:right;flex-shrink:0;}
.src-stars{font-size:13px;color:var(--tr);white-space:nowrap;}
.src-revs{font-size:11px;color:var(--cl);margin-bottom:10px;}
.ct-btn{background:var(--tr);color:var(--wh);border:none;padding:8px 16px;border-radius:18px;font-size:12px;cursor:pointer;font-family:var(--ss);width:100%;transition:background .18s;}
.ct-btn:hover{background:var(--td);}
.sv-btn{background:transparent;color:var(--cl);border:1px solid rgba(44,40,37,.15);padding:7px 14px;border-radius:18px;font-size:12px;cursor:pointer;font-family:var(--ss);margin-top:6px;width:100%;transition:all .18s;}
.sv-btn:hover{border-color:var(--tr);color:var(--tr);}

/* ── PRODUCT DETAIL ── */
.pdp-grid{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;max-width:880px;margin:0 auto;padding:2rem 2.5rem 0;}
.pdp-gal{display:flex;flex-direction:column;gap:10px;}
.pdp-main{border-radius:12px;height:300px;display:flex;align-items:center;justify-content:center;border:1px solid rgba(44,40,37,.07);}
.pdp-thumbs{display:flex;gap:8px;}
.pdp-th{width:70px;height:70px;border-radius:8px;border:2px solid transparent;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:border-color .15s;}
.pdp-th.on{border-color:var(--tr);}
.pdp-th:nth-child(1){background:var(--tp);}
.pdp-th:nth-child(2){background:var(--pl2);}
.pdp-th:nth-child(3){background:var(--sp);}
.pdp-sel-row{display:flex;align-items:center;gap:8px;margin-bottom:.75rem;}
.pdp-sel-av{width:26px;height:26px;border-radius:50%;background:var(--sp);border:1px solid var(--sl);display:flex;align-items:center;justify-content:center;font-family:var(--sf);font-size:11px;color:var(--sd);}
.pdp-sel-nm{font-size:12px;color:var(--tr);cursor:pointer;border-bottom:1px dotted var(--tl);}
.pdp-sel-lc{font-size:11px;color:var(--cl);}
.pdp-title{font-family:var(--sf);font-size:26px;font-weight:400;color:var(--ch);line-height:1.2;margin-bottom:.5rem;}
.pdp-rat{display:flex;align-items:center;gap:8px;margin-bottom:1rem;}
.pdp-stars{font-size:13px;color:var(--tr);}
.pdp-rc{font-size:12px;color:var(--cl);}
.vb{font-size:10px;background:var(--sp);color:var(--sd);border:1px solid var(--sl);padding:2px 9px;border-radius:9px;}
.pdp-price{font-family:var(--sf);font-size:32px;font-weight:300;color:var(--tr);margin-bottom:1rem;}
.ol{font-size:12px;font-weight:500;color:var(--cm);margin-bottom:.45rem;}
.swatches{display:flex;gap:8px;margin-bottom:1rem;align-items:flex-end;}
.sw{width:30px;height:30px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:border-color .15s;}
.sw.on{border-color:var(--ch);}
.swl{font-size:11px;color:var(--cl);text-align:center;margin-top:3px;}
.sz-row{display:flex;gap:7px;margin-bottom:1rem;flex-wrap:wrap;}
.sz{padding:7px 13px;border:1px solid rgba(44,40,37,.18);border-radius:6px;background:var(--wh);color:var(--cm);font-size:12px;font-family:var(--ss);cursor:pointer;transition:all .15s;}
.sz.on{border-color:var(--tr);background:var(--tp);color:var(--td);}
.qty-row{display:flex;align-items:center;gap:12px;margin-bottom:1.2rem;}
.qty-ctrl{display:flex;align-items:center;border:1px solid rgba(44,40,37,.2);border-radius:8px;overflow:hidden;}
.qb{width:32px;height:32px;background:var(--pl);border:none;font-size:17px;cursor:pointer;color:var(--ch);font-family:var(--ss);display:flex;align-items:center;justify-content:center;}
.qv{width:36px;text-align:center;font-size:14px;font-weight:500;color:var(--ch);}
.ship-note{font-size:12px;color:var(--cm);}
.prsnl-note{background:var(--sp);border:1px solid var(--sl);border-radius:8px;padding:.75rem 1rem;font-size:12px;color:var(--sd);margin-bottom:1.1rem;line-height:1.6;}
.add-btn{background:var(--tr);color:var(--wh);border:none;width:100%;padding:14px;border-radius:26px;font-size:14px;font-family:var(--ss);cursor:pointer;margin-bottom:9px;transition:background .18s;}
.add-btn:hover{background:var(--td);}
.wish-btn{background:transparent;color:var(--ch);border:1.5px solid rgba(44,40,37,.2);width:100%;padding:12px;border-radius:26px;font-size:13px;font-family:var(--ss);cursor:pointer;transition:all .18s;}
.wish-btn:hover{border-color:var(--tr);color:var(--tr);}
.tr-list{display:flex;flex-direction:column;gap:8px;margin-top:1rem;padding-top:1rem;border-top:1px solid rgba(44,40,37,.08);}
.tr-row{display:flex;align-items:center;gap:10px;}
.tr-txt{font-size:12px;color:var(--cm);}
.pdp-tabs{display:flex;border-bottom:1px solid rgba(44,40,37,.1);max-width:880px;margin:1.5rem auto 0;padding:0 2.5rem;}
.pdp-tab{padding:11px 18px;font-size:13px;font-family:var(--ss);color:var(--cl);cursor:pointer;border:none;background:none;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all .18s;}
.pdp-tab.on{color:var(--tr);border-bottom-color:var(--tr);font-weight:500;}
.tab-pane{display:none;}.tab-pane.on{display:block;}
.tab-body{max-width:880px;margin:0 auto;padding:1.75rem 2.5rem 2rem;}
.det-row{display:flex;font-size:13px;color:var(--cm);padding:7px 0;border-bottom:1px solid rgba(44,40,37,.05);}
.det-row span:first-child{color:var(--cl);min-width:135px;}
.rb-row{display:flex;align-items:center;gap:7px;margin-bottom:5px;}
.rb-bg{flex:1;height:5px;background:var(--pl2);border-radius:3px;}
.rb-f{height:100%;background:var(--tr);border-radius:3px;}
.rv-c{border-bottom:1px solid rgba(44,40,37,.07);padding-bottom:1.2rem;margin-bottom:1.2rem;}
.rv-hd{display:flex;justify-content:space-between;margin-bottom:.35rem;}
.rv-nm{font-size:13px;font-weight:500;color:var(--ch);}
.rv-dt{font-size:11px;color:var(--cl);}
.rv-st{font-size:12px;color:var(--tr);margin-bottom:.3rem;}
.rv-tx{font-size:13px;color:var(--cm);line-height:1.6;}
.sp-card{background:var(--tvp);border-radius:10px;padding:1.25rem;display:flex;gap:1.2rem;align-items:flex-start;}
.sp-av{width:52px;height:52px;border-radius:50%;background:var(--sp);border:2px solid var(--sl);display:flex;align-items:center;justify-content:center;font-family:var(--sf);font-size:20px;color:var(--sd);flex-shrink:0;}
.sp-nm{font-size:15px;font-weight:500;color:var(--ch);margin-bottom:2px;}
.sp-lc{font-size:12px;color:var(--cl);margin-bottom:.5rem;}
.sp-bio{font-size:13px;color:var(--cm);line-height:1.6;margin-bottom:.75rem;}
.sp-sts{display:flex;gap:1rem;}
.sp-sn{font-family:var(--sf);font-size:18px;color:var(--ch);}
.sp-sl{font-size:11px;color:var(--cl);}
.rel-g{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;max-width:880px;margin:0 auto;padding:0 2.5rem 2.5rem;}

/* ── SHOP GOODS PAGE ── */
.filter-strip{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:1.5rem;align-items:center;}
.filter-strip span{font-size:12px;color:var(--cl);}
.filter-strip select{font-size:12px;color:var(--cm);border:1px solid rgba(44,40,37,.15);border-radius:6px;padding:5px 10px;background:var(--wh);font-family:var(--ss);outline:none;}

/* ── LIST WITH US LANDING ── */
.type-cards{display:grid;grid-template-columns:1fr 1fr;gap:16px;max-width:620px;margin:0 auto 0;}
.tc{background:var(--wh);border:2px solid rgba(44,40,37,.12);border-radius:12px;padding:1.75rem 1.5rem;text-align:center;cursor:pointer;transition:all .2s;}
.tc:hover{border-color:var(--tl);background:var(--tvp);}
.tc-icon{width:54px;height:54px;margin:0 auto 1rem;display:flex;align-items:center;justify-content:center;}
.tc-title{font-family:var(--sf);font-size:22px;font-weight:400;color:var(--ch);margin-bottom:.4rem;}
.tc-desc{font-size:13px;color:var(--cl);line-height:1.5;}

/* ── VENDOR FORMS ── */
.fi{width:100%;padding:10px 14px;border:1px solid rgba(44,40,37,.2);border-radius:8px;font-family:var(--ss);font-size:13px;color:var(--ch);background:var(--wh);outline:none;transition:border-color .15s;}
.fi:focus{border-color:var(--tr);}
.fi::placeholder{color:var(--cl);}
textarea.fi{resize:vertical;min-height:90px;}
.fl-label{font-size:12px;font-weight:500;color:var(--cm);margin-bottom:.4rem;display:block;}
.fl-label span{font-weight:400;color:var(--cl);}
.fg{margin-bottom:1.25rem;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.fg3{display:grid;grid-template-columns:2fr 1fr 1fr;gap:12px;}
.form-section{margin-bottom:2rem;}
.form-sh{font-family:var(--sf);font-size:22px;font-weight:400;color:var(--ch);margin-bottom:.25rem;padding-bottom:.6rem;border-bottom:1px solid rgba(44,40,37,.08);}
.form-sh-sub{font-size:13px;color:var(--cl);margin-bottom:1.25rem;}
.rc-card{border:1px solid rgba(44,40,37,.14);border-radius:8px;padding:12px 14px;cursor:pointer;display:flex;align-items:flex-start;gap:10px;margin-bottom:10px;transition:all .15s;}
.rc-card:hover{border-color:var(--tl);}
.rc-card.on{border-color:var(--tr);background:var(--tvp);}
.rc-dot{width:16px;height:16px;border-radius:50%;border:1.5px solid rgba(44,40,37,.3);margin-top:2px;flex-shrink:0;display:flex;align-items:center;justify-content:center;}
.rc-card.on .rc-dot{border-color:var(--tr);}
.rc-in{width:8px;height:8px;border-radius:50%;background:transparent;}
.rc-card.on .rc-in{background:var(--tr);}
.rc-title{font-size:13px;font-weight:500;color:var(--ch);}
.rc-desc{font-size:12px;color:var(--cl);margin-top:2px;line-height:1.5;}
.cp-row{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:1.25rem;}
.cp{background:var(--pl);border:1px solid rgba(44,40,37,.12);color:var(--cm);padding:6px 13px;border-radius:15px;font-size:12px;cursor:pointer;font-family:var(--ss);transition:all .15s;}
.cp:hover,.cp.on{background:var(--tr);color:var(--wh);border-color:var(--tr);}
.cp.sg-pill:hover,.cp.sg-pill.on{background:var(--sg);border-color:var(--sg);}
.upload-zone{border:1.5px dashed rgba(44,40,37,.25);border-radius:10px;padding:1.75rem 1.5rem;text-align:center;cursor:pointer;transition:all .2s;background:var(--pl);}
.upload-zone:hover{border-color:var(--tr);background:var(--tvp);}
.price-row{display:grid;grid-template-columns:1fr auto auto auto;gap:10px;align-items:center;padding:.6rem 0;border-bottom:1px solid rgba(44,40,37,.06);}
.price-row:last-child{border-bottom:none;}
.price-del{width:24px;height:24px;border-radius:50%;background:none;border:1px solid rgba(44,40,37,.15);font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--cl);}
.price-del:hover{border-color:var(--tr);color:var(--tr);}
.add-row-btn{font-size:12px;color:var(--tr);background:none;border:none;font-family:var(--ss);cursor:pointer;padding:0;margin-top:.5rem;}
.avail-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:1.25rem;}
.avail-day{background:var(--pl);border:1px solid rgba(44,40,37,.12);border-radius:7px;padding:8px 4px;text-align:center;cursor:pointer;transition:all .15s;}
.avail-day.on{background:var(--sg);border-color:var(--sg);}
.avail-day span{display:block;font-size:11px;font-weight:500;color:var(--ch);}
.avail-day.on span{color:var(--wh);}
.plan-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-bottom:1.5rem;}
.plan-c{background:var(--wh);border:1.5px solid rgba(44,40,37,.12);border-radius:12px;padding:1.4rem 1.2rem;cursor:pointer;transition:all .18s;text-align:center;}
.plan-c:hover{border-color:var(--tl);}
.plan-c.on{border:2px solid var(--tr);}
.plan-pop{display:inline-block;font-size:10px;background:var(--sp);color:var(--sd);border:1px solid var(--sl);padding:2px 10px;border-radius:9px;margin-bottom:.6rem;}
.plan-name{font-family:var(--sf);font-size:20px;font-weight:400;color:var(--ch);margin-bottom:.25rem;}
.plan-price{font-size:22px;font-weight:500;color:var(--tr);margin-bottom:.6rem;}
.plan-price span{font-size:13px;font-weight:400;color:var(--cl);}
.plan-feat{list-style:none;text-align:left;margin-top:.75rem;}
.plan-feat li{font-size:12px;color:var(--cm);padding:4px 0;border-bottom:1px solid rgba(44,40,37,.05);display:flex;align-items:center;gap:7px;}
.plan-feat li:last-child{border-bottom:none;}
.steps-bar{display:flex;align-items:center;justify-content:center;padding:1.2rem 2rem;background:var(--wh);border-bottom:1px solid rgba(44,40,37,.07);gap:0;flex-wrap:wrap;}
.sdot{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:500;font-family:var(--ss);border:1.5px solid rgba(44,40,37,.2);color:var(--cl);background:var(--wh);flex-shrink:0;transition:all .25s;}
.sdot.dn{background:var(--sg);border-color:var(--sg);color:var(--wh);}
.sdot.ac{background:var(--tr);border-color:var(--tr);color:var(--wh);}
.slbl{font-size:12px;color:var(--cl);margin:0 7px;white-space:nowrap;}
.slbl.ac{color:var(--tr);font-weight:500;}
.slbl.dn{color:var(--ch);}
.sln{width:32px;height:1px;background:rgba(44,40,37,.15);flex-shrink:0;}
.sln.dn{background:var(--sg);}
.form-layout{display:grid;grid-template-columns:1fr 280px;gap:0;max-width:880px;margin:0 auto;}
.form-main{padding-right:2.5rem;}
.form-side{border-left:1px solid rgba(44,40,37,.08);padding-left:2rem;}
.form-side-lbl{font-size:12px;font-weight:500;color:var(--cm);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:1px solid rgba(44,40,37,.08);}
.btn-row{display:flex;gap:12px;margin-top:1rem;align-items:center;}
.review-block{background:var(--pl);border-radius:10px;padding:1rem 1.25rem;margin-bottom:1rem;}
.rb-lbl{font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--cl);margin-bottom:.4rem;}
.rb-val{font-size:13px;color:var(--ch);line-height:1.7;}

/* ── WHERE TO START PAGE ── */
.guide-intro{background:var(--wh);padding:3.5rem 2.5rem 2rem;text-align:center;}
.guide-intro h1{font-family:var(--sf);font-size:44px;font-weight:300;line-height:1.15;color:var(--ch);margin-bottom:1rem;}
.guide-intro h1 em{font-style:italic;color:var(--tr);}
.guide-intro p{font-size:15px;color:var(--cm);max-width:560px;margin:0 auto 1rem;line-height:1.78;}
.gsc{background:var(--wh);border:1px solid rgba(44,40,37,.09);border-radius:12px;padding:1.5rem 1.6rem;cursor:pointer;transition:all .2s;display:flex;gap:1.25rem;align-items:flex-start;}
.gsc:hover{border-color:var(--tl);transform:translateY(-2px);}
.gsc.sage:hover{border-color:var(--sl);}
.gsc-icon{width:48px;height:48px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.gsc-icon.t{background:var(--tp);}
.gsc-icon.s{background:var(--sp);}
.gsc-name{font-family:var(--sf);font-size:20px;font-weight:400;color:var(--ch);margin-bottom:.3rem;}
.gsc-tagline{font-size:12px;font-weight:500;letter-spacing:.06em;text-transform:uppercase;color:var(--tr);margin-bottom:.5rem;}
.gsc-tagline.sg{color:var(--sg);}
.gsc-desc{font-size:13px;color:var(--cm);line-height:1.7;margin-bottom:.75rem;}
.gsc-when{font-size:12px;color:var(--cl);font-style:italic;line-height:1.6;border-top:1px solid rgba(44,40,37,.07);padding-top:.65rem;}
.gsc-link{display:inline-flex;align-items:center;gap:5px;margin-top:.75rem;font-size:12px;color:var(--tr);border-bottom:1px dotted var(--tl);cursor:pointer;}
.gsc-link:hover{color:var(--td);}
.gsc-link.sg{color:var(--sg);border-bottom-color:var(--sl);}
.gsc-link.sg:hover{color:var(--sd);}
.sec-div{text-align:center;padding:1.75rem 0 .5rem;}
.sec-div span{font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--cl);}
.gd-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:12px;}
.gmc{background:var(--wh);border:1px solid rgba(44,40,37,.09);border-radius:10px;padding:1.1rem 1.25rem;cursor:pointer;transition:all .18s;display:flex;gap:12px;align-items:flex-start;}
.gmc:hover{border-color:rgba(193,99,79,.3);}
.gmc-icon{width:38px;height:38px;border-radius:8px;background:var(--tp);display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.gmc-name{font-size:13px;font-weight:500;color:var(--ch);margin-bottom:3px;}
.gmc-desc{font-size:12px;color:var(--cl);line-height:1.5;}

/* ── CONFIRMATION ── */
.conf-wrap{max-width:560px;margin:0 auto;padding:2.5rem 2rem 3rem;text-align:center;}
.conf-icon{width:64px;height:64px;border-radius:50%;background:var(--sp);border:2px solid var(--sl);display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;}
.conf-next{background:var(--wh);border:1px solid rgba(44,40,37,.1);border-radius:10px;padding:1.1rem 1.25rem;margin-bottom:.75rem;display:flex;align-items:flex-start;gap:12px;text-align:left;}
.cn-num{width:26px;height:26px;border-radius:50%;background:var(--tr);color:var(--wh);font-size:12px;font-weight:500;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px;}
.cn-title{font-size:13px;font-weight:500;color:var(--ch);margin-bottom:2px;}
.cn-desc{font-size:12px;color:var(--cl);line-height:1.5;}
</style>
</head>
<body>

<div id="app">

<!-- ══════════════════════════════════════════════════════════
     PAGE 0 — LANDING
══════════════════════════════════════════════════════════ -->
<div class="pg on" id="p0">
<nav>
  <a class="logo" onclick="go(0)">
    <svg width="44" height="44" viewBox="0 0 46 46" fill="none"><path d="M36,23 A16,16 0 0,1 36,22.6 A16,16 0 1,0 36,23" stroke="#C1634F" stroke-width="4" stroke-linecap="round" fill="none"/><path d="M29,23 A10,10 0 0,1 29,22.7 A10,10 0 1,0 29,23" stroke="#7A9E82" stroke-width="3" stroke-linecap="round" fill="none"/></svg>
    <div><div class="ln"><span class="ca">Coda</span><span class="co">Co</span></div><div class="lt">A curated marketplace for death and dying</div></div>
  </a>
  <ul class="nl">
    <li><a onclick="go(3)">Shop goods</a></li>
    <li><a onclick="go(1)">Find services</a></li>
    <li><a>Books</a></li>
    <li><a>Light &amp; dark</a></li>
    <li><a onclick="go(4)">List with us</a></li>
    <li><a class="cta">Sign in</a></li>
  </ul>
</nav>

<div class="hero">
  <div class="ey">Welcome</div>
  <h1>Everything you need to plan<br><em>a meaningful end.</em></h1>
  <p class="hero-tag">CodaCo connects you with thoughtfully curated goods, local services and expert resources to help you approach death — yours or someone you love — with grace and intention.</p>
  <p class="hero-tag2">Death is a part of life. Support shouldn't be hard to find.</p>
  <div class="hs-row">
    <input type="text" id="hs0" placeholder="Search goods, services, books…"/>
    <button onclick="doSearch('hs0')">Search</button>
  </div>
  <div class="hero-guide-txt">Someone I love just died — <a onclick="go(9)">I don't know where to start →</a></div>
  <div class="guide-toggle-lnk"><a onclick="toggleGuide()">Or answer a few questions to find what you need ↓</a></div>

  <div class="gp" id="gp">
    <h3 id="gt">What brings you to CodaCo today?</h3>
    <div class="gb" id="gb">
      <button class="gb-btn featured" onclick="showSub('recently')">
        <span class="gb-title">Someone I love just died</span>
        <span class="gb-desc">I don't know where to start</span>
      </button>
      <button class="gb-btn" onclick="showSub('planning')">
        <span class="gb-title">Planning ahead</span>
        <span class="gb-desc">Documents, workbooks, directives</span>
      </button>
      <button class="gb-btn" onclick="showSub('memorial')">
        <span class="gb-title">Memorial &amp; burial</span>
        <span class="gb-desc">Urns, shrouds, ash jewelry</span>
      </button>
      <button class="gb-btn" onclick="showSub('learn')">
        <span class="gb-title">Learning &amp; exploring</span>
        <span class="gb-desc">Books, humor, community</span>
      </button>
    </div>
    <div class="gs" id="gs-recently">
      <p style="font-size:13px;color:var(--cm);margin-bottom:.75rem;">We're so sorry for your loss. Here is a gentle guide to what might help right now.</p>
      <button onclick="go(9)" style="background:var(--tr);color:var(--wh);border:none;padding:10px 22px;border-radius:20px;font-size:13px;font-family:var(--ss);cursor:pointer;width:100%;">See the full guide: where to start →</button>
      <button class="guide-back" onclick="resetGuide()">← Back</button>
    </div>
    <div class="gs" id="gs-planning">
      <p style="font-size:13px;color:var(--cm);margin-bottom:.5rem;">Planning ahead:</p>
      <div class="sub-tags">
        <span class="sub-tag" onclick="go(3)">Advance care templates</span>
        <span class="sub-tag" onclick="go(3)">EOL workbooks</span>
        <span class="sub-tag" onclick="go(1)">Estate attorneys</span>
        <span class="sub-tag" onclick="go(1)">Death doulas</span>
      </div>
      <button class="guide-back" onclick="resetGuide()">← Back</button>
    </div>
    <div class="gs" id="gs-memorial">
      <p style="font-size:13px;color:var(--cm);margin-bottom:.5rem;">Memorial items:</p>
      <div class="sub-tags">
        <span class="sub-tag" onclick="go(3)">Urns &amp; vessels</span>
        <span class="sub-tag" onclick="go(3)">Ash jewelry</span>
        <span class="sub-tag" onclick="go(3)">Burial shrouds</span>
        <span class="sub-tag" onclick="go(3)">Custom keepsakes</span>
      </div>
      <button class="guide-back" onclick="resetGuide()">← Back</button>
    </div>
    <div class="gs" id="gs-learn">
      <p style="font-size:13px;color:var(--cm);margin-bottom:.5rem;">Explore &amp; learn:</p>
      <div class="sub-tags">
        <span class="sub-tag">Books on death</span>
        <span class="sub-tag">Dark humor gifts</span>
        <span class="sub-tag">Briefly Perfectly Human</span>
        <span class="sub-tag">Smoke Gets in Your Eyes</span>
      </div>
      <button class="guide-back" onclick="resetGuide()">← Back</button>
    </div>
