# Local Postgres connection. Copy to .env and adjust for your machine.
# Easiest path: run `npx prisma dev start --detach` (Prisma 7 ships an
# embedded Postgres + shadow DB) and paste the two URLs it prints in
# here. See AGENTS.md → "Local DB for migration generation" for the
# full workflow.
DATABASE_URL="postgresql://codaco:codaco_dev@127.0.0.1:5432/codaco_dev?schema=public"

# Shadow DB for `prisma migrate dev` and `prisma migrate diff` to
# detect drift. Required to generate migrations locally; not used in
# CI/prod (`migrate deploy` only reads DATABASE_URL).
SHADOW_DATABASE_URL="postgresql://codaco:codaco_dev@127.0.0.1:5432/codaco_shadow?schema=public"

# Auth.js secret (Phase C). Generate with `openssl rand -base64 32`.
AUTH_SECRET=""

# Shared secret required to create an account. Fail-closed: if this is
# unset, /signup is disabled entirely. Hand the code to prospective
# vendors during demo calls and rotate when it leaks.
INVITE_CODE="dev"

# Preview-gate password. When set, every route except /homepage,
# /preview-access, and static assets requires this password (entered
# once per device, cached in an httpOnly cookie). Leave unset for local
# dev so the gate is bypassed entirely. Set in Vercel for preview and
# production environments to keep the WIP site private.
PREVIEW_PASSWORD=""

# Resend API key (https://resend.com). Powers the transactional
# emails: application submitted / approved / rejected. When unset,
# email sends are skipped with a warning log instead of crashing —
# the underlying flow (apply, approve, reject) still works, the
# recipient just doesn't get a message.
RESEND_API_KEY=""

# Sender identity for transactional emails. The domain (codaco.market)
# must be verified in the Resend dashboard before sends will succeed.
# Defaults to this value in code; override here to test from a
# different address.
RESEND_FROM="CodaCo <hello@codaco.market>"
