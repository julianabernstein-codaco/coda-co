// Phase B schema: covers the entities the current app reads. Tables for
// users / orders / vendor_applications / subscriptions land in their own
// phases — see docs/data-model-evolution.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Catalog: types ────────────────────────────────────────────────────────────

// Renamed from `categories` to mirror `service_types`. System-seeded.
model ProductType {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]

  @@map("product_types")
}

model ServiceType {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  services Service[]

  @@map("service_types")
}

// ── Identity ──────────────────────────────────────────────────────────────────

// `role` is the central authorization signal. Vendors and buyers are both
// `user`; `admin` gates internal tooling. Use `unknown` as the default so a
// missing role is visible rather than silently treated as something.
enum UserRole {
  unknown
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   @map("password_hash")
  role          UserRole  @default(unknown)
  emailVerified DateTime? @map("email_verified")
  image         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accounts      Account[]
  sessions      Session[]
  vendorProfile VendorProfile?
  applications  VendorApplication[] @relation("VendorApplicationsApplicant")
  reviewedApps  VendorApplication[] @relation("VendorApplicationsReviewer")
  orders        Order[]

  // Gift cards a user bought / claimed into their account. Both are
  // optional links (a guest can buy or redeem without an account), so the
  // FK SetNull-detaches rather than cascade-deletes the card.
  giftCardsPurchased GiftCard[] @relation("GiftCardsPurchased")
  giftCardsClaimed   GiftCard[] @relation("GiftCardsClaimed")

  @@map("users")
}

// Auth.js Prisma-adapter shapes. Required even when only Credentials is in
// use today — keeps the door open for OAuth providers later without a
// follow-up migration.
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ── Vendors ───────────────────────────────────────────────────────────────────

enum VendorKind {
  unknown
  goods
  services
  both
}

// Phase C wires `user_id` to the `users` table. Backfill creates one user
// per existing vendor so the FK is enforced going forward.
model VendorProfile {
  id          String     @id @default(cuid())
  userId      String     @unique @map("user_id")
  slug        String     @unique
  displayName String     @map("display_name")
  bio         String
  location    String
  kind        VendorKind @default(unknown)
  verified    Boolean    @default(false)

  // Currently consumed by the UI but not yet covered by the docs' minimum
  // shape. Treat them as deferred-but-rendered and revisit once their
  // owners (auth, photo uploads, locations) land in later phases.
  initials    String?
  credentials String?
  distanceMi  Float?    @map("distance_mi")
  lifeStages  String[]  @default([]) @map("life_stages")
  memberSince DateTime? @map("member_since")
  photoSrc    String?   @map("photo_src")
  photoTone   String?   @map("photo_tone")

  // Public contact links — vendor-editable, shown in the contact CTA at
  // the bottom of the public profile. Both optional; render only the
  // ones the vendor fills in. instagramHandle is the raw handle (no @).
  websiteUrl      String? @map("website_url")
  instagramHandle String? @map("instagram_handle")

  // Service-area display fields shown on the public profile's "Services
  // & service area" card. Free-form text so vendors can phrase them
  // naturally ("25 mile radius", "Tue–Fri primary"). All optional.
  // serviceFormats overrides the formats string otherwise derived from
  // the vendor's services.locationType values.
  serviceRadius  String? @map("service_radius")
  serviceFormats String? @map("service_formats")
  serviceDays    String? @map("service_days")
  serviceHours   String? @map("service_hours")

  // Captured from the application form, editable later from the
  // dashboard. zip + serviceRadiusMi drive the geographic search
  // filter: a vendor surfaces for a searcher whose zip is within
  // serviceRadiusMi miles of the vendor's zip. serviceRadiusMi is
  // null for vendors with no geographic service area (virtual-only,
  // goods that ship nationwide). serviceRadius stays as the free-form
  // display string shown on the profile card.
  // serviceDescription is a vendor-level "what I do" overview shown
  // above the per-service list; pricingNotes is free-form pricing
  // context that supplements each service's structured priceCents.
  zip                String? @map("zip")
  serviceRadiusMi    Int?    @map("service_radius_mi")
  serviceDescription String? @map("service_description")
  pricingNotes       String? @map("pricing_notes")

  // Curated tag list from lib/data/specializations.ts. Drives the
  // /services filter chips — vendors declare what they specialize in,
  // clients filter to find them. Stored as a TEXT[] mirroring lifeStages.
  specializations String[] @default([])

  // Goods sellers set up their shop self-serve (no admin review of the
  // shop itself); instead their FIRST product listing is reviewed by
  // CodaCo. This flips true once that first listing is approved — after
  // which every later listing the vendor publishes goes live instantly,
  // no per-listing review. See app/admin/listings + setProductStatus.
  listingsAutoApprove Boolean @default(false) @map("listings_auto_approve")

  // One Stripe Customer per vendor, reused for both the services
  // subscription and the goods one-time set-up fee. Null until the vendor
  // first opens Checkout. (VendorPayment also stores the id for audit, but
  // this is the canonical reference for reuse.)
  stripeCustomerId String? @unique @map("stripe_customer_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  products      Product[]
  services      Service[]
  vendorReviews VendorReview[]
  inquiries     VendorInquiry[]
  subscriptions Subscription[]
  payments      VendorPayment[]
  orderItems    OrderItem[]

  @@map("vendor_profile")
}

// ── Vendor lifecycle ──────────────────────────────────────────────────────────

enum ApplicationKind {
  unknown
  goods
  services
  both
}

enum ApplicationStatus {
  unknown
  submitted
  approved
  rejected
}

enum SubscriptionPlanId {
  unknown
  starter
  standard
  pro
}

enum SubscriptionKind {
  unknown
  goods
  services
}

enum SubscriptionStatus {
  unknown
  incomplete
  trialing
  active
  past_due
  unpaid
  cancelled
}

// Billing cadence for a recurring (services) subscription. Set from the
// Stripe subscription's price interval. Free/one-time plans stay `unknown`.
enum SubscriptionInterval {
  unknown
  month
  year
}

// Submitted before a vendor exists; on approval, an admin (or the demo
// auto-approve flag) creates a `vendor_profile` + `subscription` and the
// applicant becomes a vendor. Type-specific fields (credentials,
// service_type, specializations) are intentionally deferred until the
// approval UI needs them.
model VendorApplication {
  id                  String             @id @default(cuid())
  applicantUserId     String             @map("applicant_user_id")
  kind                ApplicationKind    @default(unknown)
  proposedDisplayName String             @map("proposed_display_name")
  proposedSlug        String             @map("proposed_slug")
  proposedBio         String             @map("proposed_bio")
  location            String
  planId              SubscriptionPlanId @default(unknown) @map("plan_id")
  status              ApplicationStatus  @default(submitted)
  reviewedByUserId    String?            @map("reviewed_by_user_id")
  reviewedAt          DateTime?          @map("reviewed_at")
  reviewNotes         String?            @map("review_notes")
  // Specializations the applicant declared. Copied to vendor_profile
  // on approval — same shape, same canonical list.
  specializations     String[]           @default([])
  // Captured from the application form, editable later from the
  // dashboard. zip is used by the future radius-sort feature;
  // serviceDescription is a vendor-level "what I do" overview shown
  // above the per-service list; pricingNotes is free-form pricing
  // context that supplements each service's structured priceCents.
  zip                String?              @map("zip")
  serviceRadiusMi    Int?                 @map("service_radius_mi")
  serviceDescription String?              @map("service_description")
  pricingNotes       String?              @map("pricing_notes")
  lifeStages         String[]             @default([]) @map("life_stages")
  // Captured so approval can auto-create the vendor's first draft
  // Service row from their application data — no need for a second
  // /dashboard/services/new form on the way in.
  serviceTypeSlug    String?              @map("service_type_slug")
  serviceLocationType ServiceLocationType @default(unknown) @map("service_location_type")
  // Availability the applicant picked at signup (joined day/hour pills).
  // Copied to the vendor_profile's display fields on approval so the
  // public "Service area & availability" card is populated from day one.
  serviceDays         String?             @map("service_days")
  serviceHours        String?             @map("service_hours")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")

  applicant User  @relation("VendorApplicationsApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  reviewer  User? @relation("VendorApplicationsReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([applicantUserId])
  @@index([status])
  @@map("vendor_applications")
}

// Created on approval. A vendor with kind=both can hold two subscriptions
// (one goods, one services) — that's why kind lives on the row rather
// than the vendor.
model Subscription {
  id               String               @id @default(cuid())
  vendorId         String               @map("vendor_id")
  planId           SubscriptionPlanId   @default(unknown) @map("plan_id")
  kind             SubscriptionKind     @default(unknown)
  status           SubscriptionStatus   @default(unknown)
  interval         SubscriptionInterval @default(unknown)
  currentPeriodEnd DateTime?            @map("current_period_end")

  // Stripe Billing linkage for recurring (services) plans. Both null until
  // the vendor completes Checkout from the dashboard; the webhook fills
  // them in. Goods one-time charges live in VendorPayment, not here.
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  stripePriceId        String? @map("stripe_price_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("subscriptions")
}

// One-time charges owed by / collected from a vendor — today just the
// Storefront plan's set-up fee. Kept separate from `subscriptions`
// (which model the recurring plan relationship) so one-time charges,
// refunds, and their Stripe references don't muddy subscription
// semantics. Rows are created at signup in `pending`; the Stripe
// integration (next) sets `stripe_payment_intent_id` + `paid_at` and
// flips the status to `paid`.
enum VendorPaymentType {
  unknown
  setup_fee
}

enum VendorPaymentStatus {
  unknown
  pending
  paid
  failed
  refunded
}

model VendorPayment {
  id          String              @id @default(cuid())
  vendorId    String              @map("vendor_id")
  // Snapshot of the plan this charge was for. Plans are code-defined
  // (no plans table), so we store the enum value rather than FK it.
  planId      SubscriptionPlanId  @default(unknown) @map("plan_id")
  type        VendorPaymentType   @default(unknown)
  status      VendorPaymentStatus @default(unknown)
  amountCents Int                 @map("amount_cents")
  currency    String              @default("USD")

  // Stripe linkage — null until the Stripe integration settles the
  // charge. stripeCustomerId is the Stripe Customer; paymentIntent is
  // the one-time charge object.
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  paidAt                DateTime? @map("paid_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@map("vendor_payments")
}

// ── Catalog: products ─────────────────────────────────────────────────────────

enum ProductStatus {
  unknown
  draft
  // A vendor's first listing sits here after they submit it — hidden from
  // /shop until a CodaCo admin approves it (see VendorProfile.listingsAutoApprove).
  pending_review
  published
  archived
}

model Product {
  id            String        @id @default(cuid())
  vendorId      String        @map("vendor_id")
  productTypeId String        @map("product_type_id")
  slug          String        @unique
  title         String
  description   String
  // Price + currency live on `product_variants` — every product must
  // have at least one variant, and the variant's price is what buyers
  // are charged. Listings derive a display range from the variant set.
  details       Json          @default("{}")
  status        ProductStatus @default(unknown)

  // Currently consumed by the UI; tied to vendor verification in the doc.
  // Stays here so per-product overrides remain possible without a refactor.
  verified   Boolean  @default(false)
  // Front-end uses these for filter chips + the recommended-products
  // heuristic. Both stay until curation has its own table.
  lifeStages String[] @default([]) @map("life_stages")

  // Square cropped 1024×1024 webp. Required at publish; nullable so
  // drafts can exist without one. Gallery images live in product_images.
  coverImageUrl String? @map("cover_image_url")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendor      VendorProfile    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  productType ProductType      @relation(fields: [productTypeId], references: [id])
  variants    ProductVariant[]
  reviews     ProductReview[]
  images      ProductImage[]

  @@index([vendorId])
  @@index([productTypeId])
  @@map("products")
}

// Free-form gallery photos shown after the cover on the product detail
// page carousel. Any aspect ratio, normalized to max 2048px long-edge
// webp at upload time. Cap of 5 enforced in the server action.
model ProductImage {
  id        String   @id @default(cuid())
  productId String   @map("product_id")
  url       String
  alt       String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
  @@map("product_images")
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  label      String
  priceCents Int      @map("price_cents")
  currency   String   @default("USD")
  stock      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_variants")
}

// ── Catalog: services ─────────────────────────────────────────────────────────

enum ServiceStatus {
  unknown
  draft
  published
  archived
}

enum ServiceLocationType {
  unknown
  virtual
  in_person
  both
}

enum ServicePricingModel {
  unknown
  fixed
  hourly
  quote
}

model Service {
  id            String              @id @default(cuid())
  vendorId      String              @map("vendor_id")
  serviceTypeId String              @map("service_type_id")
  slug          String              @unique
  title         String
  description   String
  locationType  ServiceLocationType @default(unknown) @map("location_type")
  pricingModel  ServicePricingModel @default(unknown) @map("pricing_model")
  priceCents    Int?                @map("price_cents")
  currency      String              @default("USD")
  status        ServiceStatus       @default(unknown)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  vendor      VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  serviceType ServiceType   @relation(fields: [serviceTypeId], references: [id])

  @@index([vendorId])
  @@index([serviceTypeId])
  @@map("services")
}

// ── Reviews ───────────────────────────────────────────────────────────────────

// `verified_purchase` and `order_item_id` land in Phase F once orders
// exist. Until then `author_user_id` is also deferred (Phase C) — the
// reviewer's name and location live on the row.
model ProductReview {
  id               String   @id @default(cuid())
  productId        String   @map("product_id")
  // Phase C will replace these author fields with `author_user_id`.
  reviewerName     String   @map("reviewer_name")
  reviewerLocation String   @map("reviewer_location")
  rating           Int
  body             String
  reviewedAt       DateTime @map("reviewed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_reviews")
}

model VendorReview {
  id               String   @id @default(cuid())
  vendorId         String   @map("vendor_id")
  reviewerName     String   @map("reviewer_name")
  reviewerLocation String   @map("reviewer_location")
  rating           Int
  body             String
  reviewedAt       DateTime @map("reviewed_at")
  createdAt        DateTime @default(now()) @map("created_at")

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_reviews")
}

// Client-to-vendor inquiries from the public profile contact form.
// Saved before the notification email is sent so a lead is never lost
// on a delivery failure. readAt is null until the vendor opens their
// messages — that drives the dashboard's unread badge. The client's
// email lives here (and is the email's reply-to) but the vendor's email
// is never exposed to the client.
model VendorInquiry {
  id          String    @id @default(cuid())
  vendorId    String    @map("vendor_id")
  clientName  String    @map("client_name")
  clientEmail String    @map("client_email")
  message     String
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_inquiries")
}

// ── Commerce: orders ──────────────────────────────────────────────────────────

enum OrderStatus {
  unknown
  pending
  paid
  fulfilled
  cancelled
  refunded
}

enum OrderItemFulfillmentStatus {
  unknown
  pending
  shipped
  delivered
  cancelled
  returned
}

// One order per checkout. Can span multiple vendors; per-vendor fulfillment
// lives on the items. The cart stays client-side (localStorage) — this is the
// first row written, by createOrder at checkout. Money columns are an
// integer-cents + currency snapshot taken at order time.
model Order {
  id          String      @id @default(cuid())
  buyerUserId String      @map("buyer_user_id")
  status      OrderStatus @default(unknown)
  totalCents  Int         @map("total_cents")
  currency    String      @default("USD")
  // JSONB snapshot of the shipping address taken at checkout, so historical
  // orders survive later edits/deletions to any saved-address record.
  shippingAddress Json     @map("shipping_address")
  placedAt        DateTime @default(now()) @map("placed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  buyer User        @relation(fields: [buyerUserId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([buyerUserId])
  @@index([status])
  @@map("orders")
}

// One row per cart line. Carries price/title/variant snapshots so historical
// orders survive product edits or deletes. productVariantId and vendorId are
// nullable FKs (SetNull) for the same reason — deleting the underlying
// product/vendor must not erase the order record. vendorId is what PR 4's
// /dashboard/orders scopes by.
model OrderItem {
  id               String  @id @default(cuid())
  orderId          String  @map("order_id")
  productVariantId String? @map("product_variant_id")
  vendorId         String? @map("vendor_id")
  quantity         Int
  unitPriceCents   Int     @map("unit_price_cents")
  currency         String  @default("USD")
  // Snapshots — frozen at order time so edits/deletes to the product don't
  // rewrite history.
  productTitleSnapshot String @map("product_title_snapshot")
  variantLabelSnapshot String @map("variant_label_snapshot")

  fulfillmentStatus OrderItemFulfillmentStatus @default(unknown) @map("fulfillment_status")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  order          Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: SetNull)
  vendor         VendorProfile?  @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([vendorId])
  @@index([productVariantId])
  @@map("order_items")
}

// ── Gift cards ────────────────────────────────────────────────────────────────
//
// A gift card is prepaid balance held by CodaCo as a liability. The spendable
// balance is NEVER stored as a column — it's SUM(amount_cents) over the card's
// ledger entries (signed: + loads value, − spends it). This deliberately
// avoids the denormalized-aggregate drift the project already got burned by
// (see docs/data-model-evolution.md). Full plan:
// docs/gift-cards-and-client-billing-plan.md.

enum GiftCardStatus {
  unknown
  pending // purchased, awaiting Stripe confirmation — not yet spendable
  active // funded; has (or had) a spendable balance
  depleted // balance reached zero
  void // cancelled / refunded in full before use
}

// The purchasable instrument. `code` is what the recipient enters to check or
// claim the balance. Purchaser/recipient fields are snapshots so a delivered
// card survives later account changes; purchaserUserId is null for guests.
model GiftCard {
  id                 String         @id @default(cuid())
  code               String         @unique
  initialAmountCents Int            @map("initial_amount_cents")
  currency           String         @default("USD")
  status             GiftCardStatus @default(unknown)

  purchaserUserId String?   @map("purchaser_user_id")
  purchaserEmail  String    @map("purchaser_email")
  recipientEmail  String?   @map("recipient_email")
  recipientName   String?   @map("recipient_name")
  giftMessage     String?   @map("gift_message")
  deliverAt       DateTime? @map("deliver_at")

  // How the purchase was funded. Null until the Stripe webhook confirms the
  // Checkout payment, which also flips status → active and writes the
  // +purchase ledger entry. Mirrors the VendorPayment "row first, Stripe ids
  // via webhook later" pattern.
  stripePaymentIntentId String?   @unique @map("stripe_payment_intent_id")
  fundedAt              DateTime? @map("funded_at")

  // Optional: claimed into an account so the balance surfaces automatically
  // at checkout without re-entering the code. Null = redeem-by-code only.
  claimedByUserId String? @map("claimed_by_user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaser User? @relation("GiftCardsPurchased", fields: [purchaserUserId], references: [id], onDelete: SetNull)
  claimedBy User? @relation("GiftCardsClaimed", fields: [claimedByUserId], references: [id], onDelete: SetNull)
  ledger    GiftCardLedgerEntry[]

  @@index([purchaserUserId])
  @@index([claimedByUserId])
  @@index([status])
  @@map("gift_cards")
}

enum GiftCardEntryType {
  unknown
  purchase // + : initial load
  redemption // − : spent on an order or invoice
  refund // + : value returned to the card
  adjustment // ± : manual correction (admin)
}

// Append-only signed ledger; balance = SUM(amount_cents). Corrections are new
// entries, never edits. On a redemption exactly one of orderId /
// invoicePaymentId points at what it paid for; both are plain nullable columns
// for now — the goods link lands in PR 2, the invoice link in PR 3.
model GiftCardLedgerEntry {
  id          String            @id @default(cuid())
  giftCardId  String            @map("gift_card_id")
  type        GiftCardEntryType @default(unknown)
  amountCents Int               @map("amount_cents")
  currency    String            @default("USD")

  orderId          String? @map("order_id")
  invoicePaymentId String? @map("invoice_payment_id")

  createdByUserId String?  @map("created_by_user_id")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at")

  giftCard GiftCard @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
  @@map("gift_card_ledger_entries")
}
