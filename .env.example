# Local Postgres connection. Copy to .env and adjust for your machine.
# Easiest path: run `npx prisma dev start --detach` (Prisma 7 ships an
# embedded Postgres + shadow DB) and paste the two URLs it prints in
# here. See AGENTS.md → "Local DB for migration generation" for the
# full workflow.
DATABASE_URL="postgresql://codaco:codaco_dev@127.0.0.1:5432/codaco_dev?schema=public"

# Shadow DB for `prisma migrate dev` and `prisma migrate diff` to
# detect drift. Required to generate migrations locally; not used in
# CI/prod (`migrate deploy` only reads DATABASE_URL).
SHADOW_DATABASE_URL="postgresql://codaco:codaco_dev@127.0.0.1:5432/codaco_shadow?schema=public"

# Auth.js secret (Phase C). Generate with `openssl rand -base64 32`.
AUTH_SECRET=""
